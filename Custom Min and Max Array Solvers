def find_smallest(arr):
    smallest_num = arr[0]
    for i in range(len(arr)):
        if arr[i] < smallest_num:
            smallest_num = arr[i]
    return smallest_num
print(find_smallest([15, 4, 7, 10]))


def find_biggest(arr):
    biggest_num = arr[0]
    for i in range(len(arr)):
        if arr[i] > biggest_num:
            biggest_num = arr[i]
    return biggest_num
print(find_biggest([1, 3, 4, 10]))
